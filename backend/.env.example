# 🌐 FastAPI Settings
APP_NAME="Kisan Alert AI Backend"
APP_ENV="development"
DEBUG=true
PORT=8000
HOST="0.0.0.0"

# 🔒 CORS Configurations
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# 🔥 Firebase Admin SDK
FIREBASE_PROJECT_ID="kisan-alert-ai-dev"
# Path to firebase service account key json file
FIREBASE_CREDENTIALS_PATH="config/firebase-credentials.json"

# 🧠 Google Gemini AI
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere..."

# 🗺️ Google Maps API
GOOGLE_MAPS_API_KEY="AIzaSyYourGoogleMapsApiKeyHere..."

# 📡 Earth Engine Credentials
# EARTH_ENGINE_SERVICE_ACCOUNT="earthengine-sa@project-id.iam.gserviceaccount.com"
# EARTH_ENGINE_PRIVATE_KEY_PATH="config/earthengine-private-key.pem"
