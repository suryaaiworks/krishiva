# Krishiva Frontend Environment Variables Template
# Copy this file to .env.local to customize configurations

# Next.js App Environment Configuration
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_VERSION=1.0.0

# API Endpoints & Backends
NEXT_PUBLIC_API_URL="https://generativelanguage.googleapis.com/v1beta/interactions"

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Third-party Integrations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GEMINI_API_KEY=""
